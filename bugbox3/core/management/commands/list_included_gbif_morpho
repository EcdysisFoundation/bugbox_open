import os
import csv
from pathlib import Path
from urllib.parse import urlparse

from django.core.management.base import BaseCommand
from django.db.models.functions import Lower
from bugbox3.taxonomy.models import Morphospecies, FilteredGBIFImageRecord
from bugbox3.samples.models import SpecimenImage
from bugbox3.samples.constants import ACCEPTANCE_PENDING


class Command(BaseCommand):
    help = "List morphospecies excluded from training due to < 20 GBIF images"

    MIN_IMAGES = 20

    def handle(self, *args, **options):
        gbif_root = Path("/app/bugbox3/media/gbif_images")
        valid_ranks = ["species", "family", "genus", "order", "subclass", "subfamily", "class"]

        species_morphos = Morphospecies.objects.annotate(
            gbif_rank_lower=Lower("gbif_rank")
        ).filter(
            gbif_rank_lower__in=valid_ranks
        )

        included = []

        for morpho in species_morphos:
            specimen_qs = SpecimenImage.objects.filter(
                specimen__classification_id=morpho.id,
                downloaded_image=True
            ).exclude(
                specimen__acceptance=ACCEPTANCE_PENDING
            )
            specimen_count = specimen_qs.count()

            gbif_qs = FilteredGBIFImageRecord.objects.filter(
                morphospecies=morpho,
                downloaded_image=True
            )

            filenames = []
            for img in gbif_qs:
                parsed = urlparse(img.image_url)
                ext = os.path.splitext(parsed.path)[1]
                filename = f"{img.gbif_taxon_key}_{img.occurrence_id}{ext}"
                file_path = gbif_root / filename
                if file_path.exists():
                    filenames.append(filename)

            gbif_valid_count = len(filenames)
            total_count = gbif_valid_count + specimen_count

            if total_count >= self.MIN_IMAGES:
                included.append({
                    "name": morpho.name,
                    "id": morpho.id,
                    "taxon_keys": list(gbif_qs.values_list('gbif_taxon_key', flat=True).distinct()),
                    "specimen_count": specimen_count,
                    "gbif_count": gbif_valid_count,
                    "filenames": filenames,
                })



        if not included:
            self.stdout.write(self.style.WARNING("No morphospecies met the minimum image threshold."))
            return

        for item in included:
            self.stdout.write("─" * 60)
            self.stdout.write(f"[INCLUDED] {item['name']} (ID {item['id']})")
            self.stdout.write(f"  * Taxon Key(s): {', '.join(map(str, item['taxon_keys']))}")
            self.stdout.write(f"  * Valid GBIF Images Found: {item['gbif_count']}")
            self.stdout.write(f"  * Specimen Images Found: {item['specimen_count']}")
            self.stdout.write("  * Filenames:")
            for fname in item['filenames']:
                self.stdout.write(f"     - {fname}")
        self.stdout.write(self.style.SUCCESS(f"\nTotal included morphospecies: {len(included)}"))


        output_path = Path("local_files/gbif_included.csv")
        with open(output_path, "w", newline='') as f:
            writer = csv.writer(f)
            writer.writerow(["morphos_name", "morphos_id", "taxon_keys", "specimen_count", "gbif_count", "filenames"])
            for item in included:
                writer.writerow([
                    item["name"],
                    item["id"],
                    ";".join(map(str, item["taxon_keys"])),
                    item["specimen_count"],
                    item["gbif_count"],
                    ";".join(item["filenames"])
                ])

        self.stdout.write(self.style.SUCCESS(f"\n[CSV] Exported to {output_path}"))

